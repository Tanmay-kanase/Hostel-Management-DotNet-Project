@model HostelManagement.Models.LoginViewModel

@{
    ViewData["Title"] = "Welcome";
    Layout = null; 
    
    // Determine which tab should be active (defaults to admin)
    var activeTab = ViewBag.ActiveTab as string ?? "admin";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Welcome | Hostel Management System</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #f4f6f9; display: flex; align-items: center; justify-content: center; height: 100vh; }
        .login-card { width: 100%; max-width: 450px; border-radius: 15px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); background: white; padding: 30px; }
    </style>
</head>
<body>

<div class="login-card">
    <h3 class="text-center mb-4">Hostel Management</h3>

    @if (ViewBag.ErrorMessage != null)
    {
        <div class="alert alert-danger text-center">@ViewBag.ErrorMessage</div>
    }

    <ul class="nav nav-tabs mb-4" id="loginTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link @(activeTab == "admin" ? "active" : "") w-100" id="admin-tab" data-bs-toggle="tab" data-bs-target="#admin" type="button" role="tab">Admin Login</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link @(activeTab == "student" ? "active" : "") w-100" id="student-tab" data-bs-toggle="tab" data-bs-target="#student" type="button" role="tab">Student Login</button>
        </li>
    </ul>

    <div class="tab-content" id="loginTabsContent">
        
        <div class="tab-pane fade @(activeTab == "admin" ? "show active" : "")" id="admin" role="tabpanel">
            <form asp-controller="Account" asp-action="AdminLogin" method="post">
                <div class="mb-3">
                    <label class="form-label">Username</label>
                    <input type="text" asp-for="AdminUsername" class="form-control" placeholder="Enter admin username" required>
                </div>
                <div class="mb-3">
                    <label class="form-label">Password</label>
                    <input type="password" asp-for="AdminPassword" class="form-control" placeholder="Enter password" required>
                </div>
                <button type="submit" class="btn btn-primary w-100">Login as Admin</button>
            </form>
        </div>

        <div class="tab-pane fade @(activeTab == "student" ? "show active" : "")" id="student" role="tabpanel">
            <form asp-controller="Account" asp-action="StudentLogin" method="post">
                <div class="mb-3">
                    <label class="form-label">Full Name</label>
                    <input type="text" asp-for="StudentName" class="form-control" placeholder="As per admission form" required>
                </div>
                <div class="mb-3">
                    <label class="form-label">Date of Birth</label>
                    <input type="date" asp-for="StudentDOB" class="form-control" required>
                </div>
                <button type="submit" class="btn btn-success w-100">Login as Student</button>
            </form>
        </div>

    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>